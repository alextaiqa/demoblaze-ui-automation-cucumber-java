<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--parallel="methods" - cucumber scenarios, parallel="classes" - runner classes, parallel="tests" - test blocks-->
<suite name="Cucumber Suite" parallel="classes" thread-count="2" data-provider-thread-count="2">
    <test name="UI Tests">
        <classes>
            <class name="runners.UIRunnerTest"/>
            <class name="runners.NavBarRunnerTest"/>
        </classes>
    </test>
</suite>