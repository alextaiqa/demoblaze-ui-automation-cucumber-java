<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--parallel="methods" - run cucumber scenarios, parallel="classes" - run runner classes, parallel="tests" - run test blocks-->
<!--thread-count="2" ignored in cucumber +testNG; works in pure testNG-->
<suite name="Cucumber Suite" parallel="tests" data-provider-thread-count="2">
    <test name="UI Tests">
        <classes>
            <class name="runners.UIRunnerTest"/>
            <class name="runners.NavBarRunnerTest"/>
        </classes>
    </test>
</suite>